# Supabase credentials
# Get these from: Supabase Dashboard → Project Settings → API

# Copy this file to .env and fill in your values:
#   cp .env.example .env
# Then update with your actual credentials

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Optional: test credentials for integration tests (only if you have a test account)
# Used by test/supabase_integration_test.dart to sign in and test database operations
TEST_PASSWORD=your-test-password-here
